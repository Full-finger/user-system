server:
  env: "development"  # 可选值: development, test, production
  port: ":1323"
  cors_origins:
    - "http://localhost:5173"

database:
  host: localhost
  user: CHANGE_ME_DB_USER
  password: CHANGE_ME_DB_PASSWORD
  dbname: CHANGE_ME_DB_NAME
  port: 5432
  sslmode: disable
  timezone: Asia/Shanghai

redis:
  addr: "localhost:6379"
  password: "CHANGE_ME_REDIS_PASSWORD"
  db: 0

jwt:
  secret: "CHANGE_ME_JWT_SECRET"
  expire: 24h

smtp:
  host: "smtp.example.com"
  port: 465
  username: "your-email@example.com"
  password: "CHANGE_ME_SMTP_PASSWORD"
  from: "your-email@example.com"
  tls: true
  auth: true
  # MailHog 测试配置示例:
  # host: "localhost"
  # port: 1025
  # username: ""
  # password: ""
  # from: "test@localhost"
  # tls: false
  # auth: false

captcha:
  length: 6
  type: "number"
  expire: 5m
  send_interval: 1m
  max_attempts: 0

rate_limit:
  window: 1m
  max_requests: 10

guest_jwt:
  secret: "CHANGE_ME_GUEST_JWT_SECRET"
  expire: 168h  # 7 天

# 仅当数据库中不存在任何 admin 用户时自动创建，创建后再次启动不会重复创建
# ⚠️ 首次登录后请立即修改密码
admin:
  username: "CHANGE_ME_ADMIN_USERNAME"
  password: "CHANGE_ME_ADMIN_PASSWORD"
  email: "admin@example.com"

# 反垃圾评论配置
antispam:
  max_content_length: 5000              # 评论内容最大字符数
  honeypot_field: "website"             # 蜜罐字段名（前后端动态匹配，JSON key）
  difficulty: 4                         # PoW 难度（SHA256 前导零十六进制位数，越大越耗时）
  blocked_keywords:                     # 屏蔽关键词列表
    # - "赌博"
    # - "代开发"
  dup_window: 5m                        # 重复评论检测窗口
  comment_interval: 30s                 # 同一用户两次评论最小间隔
  challenge_limit: 10                   # challenge 接口每分钟限制次数（按 IP）

log:
  level: "info"
  filename: "logs/app.log"
  max_size: 100
  max_backups: 30
  max_age: 7
  compress: true
