server:
  port: ":1323"
  cors_origins:
    - "http://localhost:5173"

database:
  host: localhost
  user: CHANGE_ME_DB_USER
  password: CHANGE_ME_DB_PASSWORD
  dbname: CHANGE_ME_DB_NAME
  port: 5432
  sslmode: disable
  timezone: Asia/Shanghai

redis:
  addr: "localhost:6379"
  password: "CHANGE_ME_REDIS_PASSWORD"
  db: 0

jwt:
  secret: "CHANGE_ME_JWT_SECRET"
  expire: 24h

smtp:
  host: "smtp.example.com"
  port: 465
  username: "your-email@example.com"
  password: "CHANGE_ME_SMTP_PASSWORD"
  from: "your-email@example.com"
  tls: true
  auth: true
  # MailHog 测试配置示例:
  # host: "localhost"
  # port: 1025
  # username: ""
  # password: ""
  # from: "test@localhost"
  # tls: false
  # auth: false

captcha:
  length: 6
  type: "number"
  expire: 5m
  send_interval: 1m
  max_attempts: 0

rate_limit:
  window: 1m
  max_requests: 10

log:
  level: "info"
  filename: "logs/app.log"
  max_size: 100
  max_backups: 30
  max_age: 7
  compress: true
