services:
  db:
    image: postgres:16
    container_name: user-system-postgres
    environment:
      POSTGRES_USER: CHANGE_ME_DB_USER
      POSTGRES_PASSWORD: CHANGE_ME_DB_PASSWORD
      POSTGRES_DB: CHANGE_ME_DB_NAME
    ports:
      - "5432:5432"
    volumes:
      - ./postgres-data:/var/lib/postgresql/data
      - ./init-scripts:/docker-entrypoint-initdb.d

  redis:
    image: redis:7
    container_name: user-system-redis
    command: redis-server --requirepass CHANGE_ME_REDIS_PASSWORD
    ports:
      - "6379:6379"
    volumes:
      - ./redis-data:/data
